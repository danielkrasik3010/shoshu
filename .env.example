# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com/api-keys (put the real key here only; never in source code)
RESEND_API_KEY=

# Sender shown in inbox. Use a verified domain in production, e.g. Shosu <hello@yourdomain.com>
# If unset, the app falls back to Shosu <onboarding@resend.dev> (Resend testing only).
RESEND_FROM_EMAIL=
